import NoveltyTheory.Core.OrganizationAbstract

/-!
# Natural bounded organization (`SPEC_057_NS4`)

**`AdmissibleBoundedOrganization`** already certifies **weak multiscale naturality** via
**`separates`** (`SPEC_054_NS1`). This module names the same predicate for inevitability packaging
without smuggling crown conclusions into the definition.
-/

namespace NoveltyTheory

namespace Core

/-- Bounded separated multiscale organization under a naturality reading (`SPEC_057_NS4`). -/
abbrev NaturalBoundedOrganization (X : Type) :=
  OrganizationAbstract.AdmissibleBoundedOrganization X

end Core

end NoveltyTheory
