# Git LFS for large binaries when needed; do not blanket-ignore `.pdf` / needed JSON without cause.

# OS
.DS_Store
Thumbs.db

# Editors / IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~

# Private keys (do not commit)
*.pem

# Logs
*.log
logs/

# Caches (exclude noisy cache dirs; do not blanket-ignore *.json — see PROJECT_SEED §7.1)
.cache/

# Python (if used later)
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Node (if used later)
node_modules/
npm-debug.log*
yarn-error.log*

# Build outputs (stack-specific — extend per project)
dist/
build/
*.egg-info/

# Lean / Lake
.lake/
lake-packages/

# LaTeX auxiliary (paper bundle — keep sources; PDF optional per repo policy)
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.toc
paper/*.synctex.gz
paper/**/*.aux
paper/**/*.bbl
paper/**/*.blg
paper/**/*.fdb_latexmk
paper/**/*.fls
paper/**/*.out
paper/**/*.toc
paper/**/*.synctex.gz
paper/**/*.dvi

# Blog post drafts (not for public repo)
paper/blog-post-draft.html

# Stray LaTeX artifacts at repo root (build cwd mistakes)
/Self-Transcending_Generators.aux
/Self-Transcending_Generators.bbl
/Self-Transcending_Generators.blg
/Self-Transcending_Generators.fdb_latexmk
/Self-Transcending_Generators.fls
/Self-Transcending_Generators.out
/Self-Transcending_Generators.toc
/Self-Transcending_Generators.pdf
